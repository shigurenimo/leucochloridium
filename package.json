{
  "name": "leuco",
  "version": "0.10.2",
  "description": "Self-hosted multi-tenant gateway that runs the Codex app-server as a Slack bot. Bun-only.",
  "keywords": [
    "bot",
    "bun",
    "codex",
    "gateway",
    "mcp",
    "slack"
  ],
  "homepage": "https://github.com/shigurenimo/leuco#readme",
  "bugs": {
    "url": "https://github.com/shigurenimo/leuco/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shigurenimo/leuco.git"
  },
  "bin": {
    "leuco": "./lib/index.ts"
  },
  "files": [
    "lib/**/*.ts",
    "lib/non-bun-stub.js",
    "!lib/**/*.test.ts",
    "!lib/**/*.bun-test.ts",
    "tsconfig.json",
    "README.md"
  ],
  "type": "module",
  "main": "./lib/api.ts",
  "module": "./lib/api.ts",
  "types": "./lib/api.ts",
  "exports": {
    ".": {
      "types": "./lib/api.ts",
      "bun": "./lib/api.ts",
      "default": "./lib/non-bun-stub.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "bun run lib/index.ts"
  },
  "dependencies": {
    "@interactive-inc/claude-funnel": "^0.60.0",
    "@interactive-inc/flume": "^0.9.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.12.16",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "vite-plus": "^0.1.20",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
