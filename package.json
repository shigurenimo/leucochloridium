{
  "name": "leuco",
  "version": "0.7.0",
  "description": "Self-hosted multi-tenant gateway that runs the Codex app-server as a Slack bot. Bun-only.",
  "keywords": [
    "bot",
    "bun",
    "codex",
    "gateway",
    "mcp",
    "slack",
    "tui"
  ],
  "homepage": "https://github.com/shigurenimo/leuco#readme",
  "bugs": {
    "url": "https://github.com/shigurenimo/leuco/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shigurenimo/leuco.git"
  },
  "bin": {
    "leuco": "./lib/index.ts"
  },
  "files": [
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "lib/non-bun-stub.js",
    "!lib/**/*.test.ts",
    "!lib/**/*.test.tsx",
    "!lib/**/*.bun-test.ts",
    "tsconfig.json",
    "README.md"
  ],
  "type": "module",
  "main": "./lib/api.ts",
  "module": "./lib/api.ts",
  "types": "./lib/api.ts",
  "exports": {
    ".": {
      "types": "./lib/api.ts",
      "bun": "./lib/api.ts",
      "default": "./lib/non-bun-stub.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "bun run lib/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentui/core": "^0.2.2",
    "@opentui/react": "^0.2.2",
    "@slack/bolt": "^4.7.2",
    "@slack/web-api": "^7.15.1",
    "hono": "^4.12.16",
    "react": "^19.2.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "vite-plus": "^0.1.20",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
